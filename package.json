{
  "name": "nexa",
  "version": "0.1.0",
  "private": true,
  "description": "Nexa — Multi-Agent AI Platform. One platform. Infinite intelligence.",
  "author": "Engr. Mejba Ahmed <https://www.mejba.me/>",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.6.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,md,json,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,md,json,yml,yaml}\"",
    "db:up": "docker compose -f docker/docker-compose.yml up -d",
    "db:down": "docker compose -f docker/docker-compose.yml down",
    "db:logs": "docker compose -f docker/docker-compose.yml logs -f",
    "db:migrate": "pnpm --filter @nexa/api prisma:migrate",
    "db:seed": "pnpm --filter @nexa/api prisma:seed",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "turbo": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": ["prettier --write"],
    "*.{json,md,yml,yaml}": ["prettier --write"]
  }
}
